# secrets.zsh.example
# Copy this file to secrets.zsh and fill in real values.
# Keep real secrets only in the local secrets.zsh file.
# Do NOT commit real secret values to Git.

# Examples:
# export EXAMPLE_SERVICE_API_KEY="replace-with-local-value"
# export EXAMPLE_SERVICE_TOKEN="replace-with-local-value"

# Put any other machine-specific or secret vars below
