# secrets.zsh.example
# Copy this file to secrets.zsh and fill in real values.
# This file contains examples of environment variables you might store here.
# Do NOT commit secrets.zsh to Git.

# Example:
export MY_API_KEY="your-api-key-here"
export AWS_SECRET_ACCESS_KEY="your-aws-secret-here"
export GITHUB_TOKEN="ghp_xxx"

# Put any other machine-specific or secret vars below
