{
    "workbench.sideBar.location": "right",
    "workbench.editor.enablePreview": false,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilotcli:claude-haiku-4.5",

    // ==========================================
    // ターミナルの文字化け対策
    // ==========================================
    // "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'Menlo', 'Monaco', monospace",
    "terminal.integrated.fontFamily": "'HackGen Console NF', 'Menlo', 'Monaco', monospace",

    // ==========================================
    // LaTeX Workshop の設定
    // ==========================================
    "latex-workshop.latex.tools": [
    {
        "name": "latexmk (platex)",
        "command": "latexmk",
        "args": [
            "-e", "$latex=q/platex %O -synctex=1 -interaction=nonstopmode %S/",
            "-e", "$bibtex=q/pbibtex %O %B/",
            "-e", "$makeindex=q/mendex %O -o %D %S/",
            "-e", "$dvipdf=q/dvipdfmx %O -o %D %S/",
            "-pdfdvi",
            "-outdir=%OUTDIR%",
            "%DOC%"
        ]
    },
    {
        "name": "export to ChatGPT Drive",
        "command": "bash",
        "args": [
            "-lc",
            "REPO_ROOT=$(git -C \"$1\" rev-parse --show-toplevel) && \"$REPO_ROOT/scripts/export_to_chatgpt_drive.sh\" \"$2\" \"$3\" \"$4\" \"$1\"",
            "bash",
            "%DIR%",
            "%DOC%",
            "%DOCFILE%",
            "%OUTDIR%"
        ],
        "cwd": "%DIR%"
    }
],
"latex-workshop.latex.recipes": [
    {
        "name": "platex -> dvipdfmx -> export to Drive",
        "tools": [
            "latexmk (platex)",
            "export to ChatGPT Drive"
        ]
    }
],
"latex-workshop.latex.recipe.default": "first",
"latex-workshop.latex.autoBuild.run": "onSave",
    
    // ビルド成功時に自動でお掃除する設定
    "latex-workshop.latex.autoClean.run": "onBuilt",

    // お掃除の方式を「指定した拡張子を消す方式(glob)」に変更する
    "latex-workshop.latex.clean.method": "glob",
    
    // お掃除する対象ファイルの一覧（末尾に *.dvi を追加しています）
    "latex-workshop.latex.clean.fileTypes": [
        "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.ilg", "*.lof", "*.log", "*.lot", "*.toc", "*.fls", "*.fdb_latexmk", "*.pdfsync", "*.synctex.gz", "*.dvi"
    ],

    "latex-workshop.view.pdf.viewer": "tab",
    "terminal.integrated.fontSize": 17,
    "workbench.editor.empty.hint": "hidden"
}